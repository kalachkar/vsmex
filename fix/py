import csv
from pathlib import Path

CSV_PATH = Path(
    r"C:\Users\ko\Desktop\vscode_papers\SANER_paper\vsmex\metadata\vsmex_metadata.csv"
)

TARGET_COLUMNS = {
    "installation_count",
    "average_rating",
    "rating_count",
}

def main():
    with CSV_PATH.open("r", encoding="utf-8", newline="") as f:
        reader = csv.DictReader(f)
        fieldnames = reader.fieldnames
        rows = list(reader)

    if not fieldnames:
        raise RuntimeError("CSV has no header")

    for col in TARGET_COLUMNS:
        if col not in fieldnames:
            raise RuntimeError(f"Missing expected column: {col}")

    changed = 0
    for row in rows:
        for col in TARGET_COLUMNS:
            val = (row.get(col) or "").strip().lower()
            if val == "none":
                row[col] = 0
                changed += 1

    with CSV_PATH.open("w", encoding="utf-8", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=fieldnames)
        writer.writeheader()
        writer.writerows(rows)

    print(f"Done. Replaced {changed} values of 'none' with 0.")

if __name__ == "__main__":
    main()
